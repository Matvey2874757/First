{
  "schemaVersion": 1,
  "id": "novaclient",
  "version": "${version}",
  "name": "NovaClient",
  "description": "Legitimate Minecraft client with gameplay improvements and custom menu",
  "authors": [
    "NovaClient Team"
  ],
  "contact": {
    "homepage": "https://novaclient.com"
  },
  "license": "MIT",
  "icon": "assets/novaclient/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.novaclient.NovaClient"
    ]
  },
  "mixins": [
    "mixins.novaclient.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.2",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  }
}
